              <stringProp name="script">import groovy.json.JsonSlurper
import java.net.URL
import java.net.HttpURLConnection

Thread.sleep(5000)

def token = vars.get(&quot;gmail_token&quot;)
log.info(&quot;TOKEN: &quot; + token)  // ← check token value

if (!token) {
    log.error(&quot;gmail_token is missing!&quot;)
    return
}

def listUrl = new URL(&quot;https://gmail.googleapis.com/gmail/v1/users/me/messages?q=newer_than:1m&amp;maxResults=5&quot;)
HttpURLConnection listConn = (HttpURLConnection) listUrl.openConnection()
listConn.setRequestMethod(&quot;GET&quot;)
listConn.setRequestProperty(&quot;Authorization&quot;, &quot;Bearer &quot; + token)

// ✅ Check response code first
def responseCode = listConn.responseCode
log.info(&quot;Response Code: &quot; + responseCode)

// ✅ Handle error response
def listResponse = responseCode == 200 ? listConn.inputStream.text : listConn.errorStream.text
log.info(&quot;Gmail Response: &quot; + listResponse)

def json = new JsonSlurper().parseText(listResponse)

if (json.messages &amp;&amp; json.messages.size() &gt; 0) {
    def messageId = json.messages[0].id
    vars.put(&quot;messageId&quot;, messageId)
    log.info(&quot;Extracted messageId: &quot; + messageId)
} else {
    log.warn(&quot;No messages found. Full response: &quot; + listResponse)
}</stringProp>
            </JSR223PreProcessor>
